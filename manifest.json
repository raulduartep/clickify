{
  "name": "ClickClock - Chrome Extension",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html",
    "default_title": "Open the popup"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.clickup.com/t/*"
      ],
      "js": [
        "src/content-script.tsx"
      ]
    }
  ]
}